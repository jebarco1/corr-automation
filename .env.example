PORT=3000
REGRID_API_TOKEN=replace_with_your_regrid_token
REGRID_BASE_URL=https://app.regrid.com
NEARBY_DEFAULT_RADIUS_MILES=0.5
NEARBY_MAX_RADIUS_MILES=25
NEARBY_DEFAULT_LIMIT=100

# Required for AI-assisted guided quoting on the home page /api/v1/ai/*
# Keep this server-side only. Never expose it to the React client.
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. When set, protected automation/sales/pricing routes require X-API-Key.
# Leave empty for open local UI development. Generate with: npm run key:generate
# CORR_CLIENT_API_KEYS=corr_replace_with_generated_key
